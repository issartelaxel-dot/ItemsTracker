# Required
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Frontend URL allowed by CORS
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,https://setup-hub.com,https://www.setup-hub.com

# Email approval workflow
ADMIN_APPROVAL_EMAIL=issartelaxel@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_app_password
SMTP_FROM=your_smtp_user

# Optional
PORT=8787
NODE_ENV=development
# For cross-site frontend/backend in production, keep cookie usable by setting SameSite=None.
# (Browsers require Secure=true when SameSite=None.)
COOKIE_SAMESITE=none
COOKIE_SECURE=true
# Keep strict TLS verification enabled in production (default = true).
# Set to false only for temporary troubleshooting with known/trusted infra.
DB_SSL_REJECT_UNAUTHORIZED=true
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_DISPLAY_NAME=Admin
